# =========================
# SERVER
# =========================
PORT=3175
API_PREFIX=api

# =========================
# DATABASE (Neon / Cloud Postgres)
# =========================
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# =========================
# JWT
# =========================
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# =========================
# SECURITY
# =========================
BCRYPT_ROUNDS=10
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# =========================
# CORS
# =========================
CORS_ORIGINS=https://your-frontend.vercel.app

# =========================
# REDIS (optional)
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379

# =========================
# CLOUDFLARE R2 STORAGE
# =========================
STORAGE_ACCOUNT_ID=dummy
STORAGE_ACCESS_KEY_ID=admin
STORAGE_SECRET_ACCESS_KEY=admin
STORAGE_BUCKET_NAME=hr-tech-dev
STORAGE_PUBLIC_URL=https://storage.your-domain.com/hr-tech-dev

# =========================
# SMTP Configuration (Gmail)
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_SENDER_EMAIL=your-email@gmail.com
SMTP_SENDER_NAME=SaaS Platform

# =========================
# Frontend URL
# =========================
FRONTEND_URL=https://your-frontend.vercel.app